{
  "buildCommand": "npx vite build && rm -f api/index.js",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/api/plans",
      "destination": "/api/plan-sync"
    },
    {
      "source": "/api/wods/:path*",
      "destination": "/api/wods/generate"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/webhooks/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}